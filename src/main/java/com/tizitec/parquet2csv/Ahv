<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
                             https://maven.apache.org/xsd/maven-4.0.0.xsd">

    <modelVersion>4.0.0</modelVersion>

    <groupId>com.tizitec</groupId>
    <artifactId>parquet-to-csv</artifactId>
    <version>1.0.0</version>
    <packaging>jar</packaging>

    <name>parquet-to-csv</name>
    <description>Generic CLI tool to convert Parquet files to CSV using PicoCLI</description>

    <properties>
        <java.version>21</java.version>
        <maven.compiler.source>21</maven.compiler.source>
        <maven.compiler.target>21</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>

        <!-- Dependency versions -->
        <picocli.version>4.7.6</picocli.version>
        <parquet.version>1.14.3</parquet.version>
        <commons-csv.version>1.12.0</commons-csv.version>
        <jackson.version>2.17.2</jackson.version>
        <slf4j.version>2.0.13</slf4j.version>
        <logback.version>1.5.8</logback.version>

        <!-- Plugin versions -->
        <maven-compiler-plugin.version>3.13.0</maven-compiler-plugin.version>
        <maven-shade-plugin.version>3.6.0</maven-shade-plugin.version>
    </properties>

    <dependencies>

        <!-- ══════════════════════════════════════
             CLI
             ══════════════════════════════════════ -->
        <dependency>
            <groupId>info.picocli</groupId>
            <artifactId>picocli</artifactId>
            <version>${picocli.version}</version>
        </dependency>

        <!-- ══════════════════════════════════════
             Parquet reading
             parquet-hadoop is needed but we surgically exclude all Hadoop
             transitive deps, then bring back only the exact jars that
             satisfy the import graph. See:
             https://blakesmith.me/2024/10/05/how-to-use-parquet-java-without-hadoop.html
             ══════════════════════════════════════ -->
        <dependency>
            <groupId>org.apache.parquet</groupId>
            <artifactId>parquet-hadoop</artifactId>
            <version>${parquet.version}</version>
            <exclusions>
                <exclusion>
                    <groupId>*</groupId>
                    <artifactId>*</artifactId>
                </exclusion>
            </exclusions>
        </dependency>

        <dependency>
            <groupId>org.apache.parquet</groupId>
            <artifactId>parquet-column</artifactId>
            <version>${parquet.version}</version>
        </dependency>

        <!-- hadoop-common must be present with its own classes — ParquetFileReader
             instantiates HadoopParquetConfiguration which directly extends
             hadoop Configuration. We exclude only the heavy optional components
             that are not needed for local file reading. -->
        <dependency>
            <groupId>org.apache.hadoop</groupId>
            <artifactId>hadoop-common</artifactId>
            <version>3.4.1</version>
            <exclusions>
                <exclusion><groupId>org.apache.hadoop</groupId><artifactId>hadoop-auth</artifactId></exclusion>
                <exclusion><groupId>org.apache.zookeeper</groupId><artifactId>zookeeper</artifactId></exclusion>
                <exclusion><groupId>org.apache.kerby</groupId><artifactId>*</artifactId></exclusion>
                <exclusion><groupId>com.sun.jersey</groupId><artifactId>*</artifactId></exclusion>
                <exclusion><groupId>javax.servlet</groupId><artifactId>*</artifactId></exclusion>
                <exclusion><groupId>org.eclipse.jetty</groupId><artifactId>*</artifactId></exclusion>
                <exclusion><groupId>org.apache.curator</groupId><artifactId>*</artifactId></exclusion>
            </exclusions>
        </dependency>
        <!-- mapreduce-client-core classes are imported by parquet-hadoop internals.
             We exclude all its own heavy transitive deps. -->
        <dependency>
            <groupId>org.apache.hadoop</groupId>
            <artifactId>hadoop-mapreduce-client-core</artifactId>
            <version>3.4.1</version>
            <exclusions>
                <exclusion><groupId>*</groupId><artifactId>*</artifactId></exclusion>
            </exclusions>
        </dependency>

        <!-- ══════════════════════════════════════
             CSV writing
             ══════════════════════════════════════ -->
        <dependency>
            <groupId>org.apache.commons</groupId>
            <artifactId>commons-csv</artifactId>
            <version>${commons-csv.version}</version>
        </dependency>

        <!-- ══════════════════════════════════════
             JSON serialization (for complex/nested Parquet fields)
             ══════════════════════════════════════ -->
        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-databind</artifactId>
            <version>${jackson.version}</version>
        </dependency>

        <!-- ══════════════════════════════════════
             Logging
             ══════════════════════════════════════ -->
        <dependency>
            <groupId>org.slf4j</groupId>
            <artifactId>slf4j-api</artifactId>
            <version>${slf4j.version}</version>
        </dependency>
        <dependency>
            <groupId>ch.qos.logback</groupId>
            <artifactId>logback-classic</artifactId>
            <version>${logback.version}</version>
        </dependency>
        <!-- Silence Hadoop's noisy log4j dependency -->
        <dependency>
            <groupId>org.slf4j</groupId>
            <artifactId>log4j-over-slf4j</artifactId>
            <version>${slf4j.version}</version>
        </dependency>

    </dependencies>

    <build>
        <plugins>

            <!-- Compiler — enable annotation processing for PicoCLI -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>${maven-compiler-plugin.version}</version>
                <configuration>
                    <source>${java.version}</source>
                    <target>${java.version}</target>
                    <annotationProcessorPaths>
                        <path>
                            <groupId>info.picocli</groupId>
                            <artifactId>picocli-codegen</artifactId>
                            <version>${picocli.version}</version>
                        </path>
                    </annotationProcessorPaths>
                    <compilerArgs>
                        <arg>-Aproject=${project.groupId}/${project.artifactId}</arg>
                    </compilerArgs>
                </configuration>
            </plugin>

            <!-- Fat JAR — single executable artifact -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-shade-plugin</artifactId>
                <version>${maven-shade-plugin.version}</version>
                <executions>
                    <execution>
                        <phase>package</phase>
                        <goals>
                            <goal>shade</goal>
                        </goals>
                        <configuration>
                            <createDependencyReducedPom>false</createDependencyReducedPom>
                            <filters>
                                <!-- Strip signatures to avoid JAR verification errors -->
                                <filter>
                                    <artifact>*:*</artifact>
                                    <excludes>
                                        <exclude>META-INF/*.SF</exclude>
                                        <exclude>META-INF/*.DSA</exclude>
                                        <exclude>META-INF/*.RSA</exclude>
                                        <exclude>META-INF/LICENSE*</exclude>
                                        <exclude>META-INF/NOTICE*</exclude>
                                    </excludes>
                                </filter>
                                <!-- Parquet ships its own shaded Jackson under shaded/parquet/...
                                     We must NOT relocate or filter it — keep it intact so that
                                     ParquetMetadataConverter can find its own Jackson at runtime -->
                                <filter>
                                    <artifact>org.apache.parquet:parquet-hadoop</artifact>
                                    <includes>
                                        <include>**</include>
                                    </includes>
                                </filter>
                            </filters>
                            <relocations>
                                <!-- Relocate OUR Jackson away from Parquet's shaded copy
                                     to avoid class conflicts at runtime in the fat JAR -->
                                <relocation>
                                    <pattern>com.fasterxml.jackson</pattern>
                                    <shadedPattern>com.tizitec.shaded.jackson</shadedPattern>
                                </relocation>
                            </relocations>
                            <transformers>
                                <!-- Main class -->
                                <transformer implementation="org.apache.maven.plugins.shade.resource.ManifestResourceTransformer">
                                    <mainClass>com.tizitec.parquet2csv.Main</mainClass>
                                </transformer>
                                <!-- Merge service files (needed by Hadoop, Avro, Parquet) -->
                                <transformer implementation="org.apache.maven.plugins.shade.resource.ServicesResourceTransformer"/>

                            </transformers>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

        </plugins>
    </build>

</project>
